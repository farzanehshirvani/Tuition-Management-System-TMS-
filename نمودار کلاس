@startuml

class 賲丿乇爻賴{
+讴丿
+賳丕賲
}

class 倬丕蹖賴{
+讴丿
+賳丕賲
}

class 讴賱丕爻{
+讴丿
+賳丕賲
+卮賴乇蹖賴
}

class 丿丕賳卮_丌賲賵夭{
+讴丿
+賳丕賲
+賳丕賲_禺丕賳賵丕丿诏蹖
+讴丿賲賱蹖
+鬲賱賮賳
}

class 倬乇賵賳丿賴_賲丕賱蹖{
+卮賲丕乇賴_倬乇賵賳丿賴
+賲亘賱睾_讴賱
+賲亘賱睾_倬乇丿丕禺鬲蹖
+賲丕賳丿賴
+賵囟毓蹖鬲
}

class 倬乇丿丕禺鬲{
